# Development Environment Variables
MONGO_URL="mongodb://127.0.0.1:27017"
DB_NAME="astramark_dev"
CORS_ORIGINS="http://localhost:3000,https://localhost:3000"

# AI Services (Get from Google Cloud Console & Groq)
GOOGLE_API_KEY=your_google_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Authentication (Generate secure keys)
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_REFRESH_SECRET_KEY=your_jwt_refresh_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Payment Gateways (Choose one or both)
# Stripe (International)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Razorpay (India & International)
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# Default payment gateway (stripe or razorpay)
DEFAULT_PAYMENT_GATEWAY=stripe

# External APIs (Optional)
SERP_API_KEY=your_serp_api_key_here

# Monitoring (Optional - only for production)
# SENTRY_DSN=your_sentry_dsn_here

# Production Settings
ENVIRONMENT=development
DEBUG=true

# Production Environment Variables (for deployment)
# MONGO_URL="mongodb+srv://username:password@cluster.mongodb.net/astramark_prod"
# DB_NAME="astramark_prod"
# CORS_ORIGINS="https://yourdomain.com"
# ENVIRONMENT=production
# DEBUG=false